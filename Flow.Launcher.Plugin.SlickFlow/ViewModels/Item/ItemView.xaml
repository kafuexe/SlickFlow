<UserControl x:Class="Flow.Launcher.Plugin.SlickFlow.ViewModels.Item.ItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:global="clr-namespace:">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <global:InverseBooleanConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="6" Margin="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Icon column -->
                <ColumnDefinition Width="40"/>
                <!-- Content column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ICON -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Image Source="{Binding IconPath}" Width="32" Height="32" Margin="0,0,0,4"/>
                <!-- Edit icon path -->
                <TextBox Text="{Binding IconPath, UpdateSourceTrigger=PropertyChanged}" 
                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" 
                         Width="36" Margin="0,2,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- CONTENT -->
            <StackPanel Grid.Column="1" Margin="6,0,0,0">

                <!-- ALIASES -->
                <TextBlock Text="{Binding AliasesString}" TextWrapping="Wrap" Margin="0,0,0,4"/>

                <!-- File -->
                <Grid Margin="0,0,0,2">
                    <TextBlock Text="{Binding FileName}" Visibility="{Binding IsEditing, Converter={StaticResource InverseBool}}"/>
                    <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Arguments -->
                <Grid Margin="0,0,0,2">
                    <TextBlock Text="{Binding ArgsDisplay}" Visibility="{Binding IsEditing, Converter={StaticResource InverseBool}}"/>
                    <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Working Dir -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="{Binding WorkingDirDisplay}" Visibility="{Binding IsEditing, Converter={StaticResource InverseBool}}"/>
                    <TextBox Text="{Binding WorkingDir, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Add new alias -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                    <TextBox Width="200" Padding="4" Text="{Binding NewAliasInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Add" Margin="6,0,0,0" Command="{Binding AddAliasCommand}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,0,6,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBool}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}" Margin="0,0,6,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
