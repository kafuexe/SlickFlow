<UserControl x:Class="Flow.Launcher.Plugin.SlickFlow.ViewModels.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Flow.Launcher.Plugin.SlickFlow.ViewModels.Item"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="600">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- DB Label -->
            <RowDefinition Height="Auto" /> <!-- DB Path + Browse -->
            <RowDefinition Height="Auto" /> <!-- Icon Label -->
            <RowDefinition Height="Auto" /> <!-- Icon Path + Browse -->
            <RowDefinition Height="Auto" /> <!-- Save button -->
            <RowDefinition Height="*" />    <!-- filler -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- DB File Label -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="DB File Path:" VerticalAlignment="Center" Margin="0,0,0,2" />

        <!-- DB File Path + Browse -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,4">
            <TextBox HorizontalAlignment="Stretch" VerticalAlignment="Center" Text="{Binding DbFilePath}" />
            <Button Content="Browse" Margin="6,0,0,0" Command="{Binding BrowseDbFolderCommand}" />
        </StackPanel>

        <!-- Icon Folder Label -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Icon Folder Path:" VerticalAlignment="Center" Margin="0,0,0,2" />

        <!-- Icon Folder Path + Browse -->
        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,0">
            <TextBox HorizontalAlignment="Stretch" VerticalAlignment="Center" Text="{Binding IconDirPath}" />
            <Button Content="Browse" Margin="6,0,0,0" Command="{Binding BrowseIconFolderCommand}" />
        </StackPanel>

        <!-- Save Button -->
        <Button Grid.Row="4" Grid.Column="0" Content="Save" HorizontalAlignment="Left" Width="80" Margin="0,6,0,0" Command="{Binding SaveCommand}" />

        <!-- Items Label -->
          <TextBlock Grid.Row="0" Grid.Column="1"
              Text="Items"
              FontWeight="Bold"
              Margin="4,4,0,4"/>

        <!-- Items List -->
        <ListBox Grid.Row="1" Grid.Column="1" Grid.RowSpan="4"
            ItemsSource="{Binding Items}"
            MaxHeight="500"
            HorizontalContentAlignment="Stretch"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            ScrollViewer.CanContentScroll="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <local:ItemView/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
