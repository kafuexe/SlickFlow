<UserControl x:Class="Flow.Launcher.Plugin.SlickFlow.ViewModels.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Flow.Launcher.Plugin.SlickFlow.ViewModels.Item"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="600">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" /> <!-- filler -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- DB File Label -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="DB File Path:" VerticalAlignment="Center" />

        <!-- DB File Path + Browse -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{Binding DbFilePath}" />

            <Button Grid.Column="1"
                    Content="Browse"
                    Margin="6,0,0,0"
                    Command="{Binding BrowseDbFolderCommand}" />
        </Grid>

        <!-- Icon Folder Label -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Icon Folder Path:" VerticalAlignment="Center" />

        <!-- Icon Folder Path + Browse -->
        <Grid Grid.Row="3" Grid.Column="0" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     VerticalAlignment="Center"
                     Text="{Binding IconDirPath}" />

            <Button Grid.Column="1"
                    Content="Browse"
                    Margin="6,0,0,0"
                    Command="{Binding BrowseIconFolderCommand}" />
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Margin="0,6,0,0">
            <Button Content="Save" Width="80" Command="{Binding SaveCommand}" />
            <Button Content="Add Item" Width="90" Margin="6,0,0,0" Command="{Binding AddItemCommand}" />
            <Button Content="Refresh" Width="80" Margin="6,0,0,0" Command="{Binding ReloadItemsCommand}" />
        </StackPanel>

        <!-- Items Label -->
          <TextBlock Grid.Row="0" Grid.Column="1"
            Text="Items"
            FontWeight="Bold"
            Margin="4,4,0,4" />

        <!-- Items List -->
        <ListBox Grid.Row="1" Grid.Column="1" Grid.RowSpan="5"
            ItemsSource="{Binding Items}"
            MaxHeight="500"
            HorizontalContentAlignment="Stretch"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling"
            ScrollViewer.CanContentScroll="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <local:ItemView />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
