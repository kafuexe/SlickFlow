<UserControl x:Class="Flow.Launcher.Plugin.SlickFlow.ViewModels.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="600">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- DB Label -->
            <RowDefinition Height="Auto" /> <!-- DB Path + Browse -->
            <RowDefinition Height="12" />   <!-- Spacer -->
            <RowDefinition Height="Auto" /> <!-- Icon Label -->
            <RowDefinition Height="Auto" /> <!-- Icon Path + Browse -->
            <RowDefinition Height="12" />   <!-- Spacer -->
            <RowDefinition Height="Auto" /> <!-- Save button -->
            <RowDefinition Height="*" />    <!-- filler -->

           <!-- List of items -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- DB File Label -->
        <TextBlock Grid.Row="0" Text="DB File Path:" VerticalAlignment="Center" />

        <!-- DB File Path + Browse -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBox Width="600" Text="{Binding DbFilePath}" />
            <Button Content="Browse" Margin="6,0,0,0" Command="{Binding BrowseDbFolderCommand}" />
        </StackPanel>

        <!-- Icon Folder Label -->
        <TextBlock Grid.Row="3" Text="Icon Folder Path:" VerticalAlignment="Center" />

        <!-- Icon Folder Path + Browse -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
            <TextBox Width="600" Text="{Binding IconDirPath}" />
            <Button Content="Browse" Margin="6,0,0,0" Command="{Binding BrowseIconFolderCommand}" />
        </StackPanel>

        <!-- Save Button -->
        <Button Grid.Row="6" Content="Save" HorizontalAlignment="Left" Width="80" Margin="0,12,0,0" Command="{Binding SaveCommand}" />

        <!-- Items Label -->
        <TextBlock Grid.Row="8"
           Text="Items"
           FontWeight="Bold"
           Margin="0,8,0,4"/>

            <!-- Items List -->
            <ListView Grid.Row="9"
                    ItemsSource="{Binding Items}"
                    Margin="0,4,0,0">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#444"
                                BorderThickness="1"
                                Padding="6"
                                Margin="0,2">

                            <StackPanel>

                                <TextBlock Text="{Binding FileName}"
                                        FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding SubTitle}"
                                        Opacity="0.7"/>

                                <TextBlock Text="{Binding Arguments}"
                                        FontStyle="Italic"
                                        Opacity="0.6"/>

                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

    </Grid>
</UserControl>
